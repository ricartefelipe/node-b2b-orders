NODE_ENV=development
APP_ENV=local
APP_NAME=node-b2b-orders
HTTP_PORT=3000

DATABASE_URL=postgresql://app:app@postgres:5432/app
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Para E2E com Fluxe B2B Suite use os mesmos valores do spring-saas-core:
# JWT_SECRET=local-dev-secret-min-32-chars-for-hs256-signing
# JWT_ISSUER=spring-saas-core
JWT_SECRET=change-me
JWT_ISSUER=local-auth
TOKEN_EXPIRES_SECONDS=3600

# Rotação sem downtime: chave anterior aceita durante transição
# JWT_SECRET_PREVIOUS=

# OIDC/RS256: para produção use RS256 com chave pública
# JWT_ALGORITHM=HS256  (default, dev)
# JWT_ALGORITHM=RS256 (produção)
# JWKS_URI: endpoint JWKS (ex: https://idp.example.com/.well-known/jwks.json)
# JWT_PUBLIC_KEY: PEM da chave pública (alternativa ao JWKS_URI)
JWT_ALGORITHM=HS256
JWKS_URI=
# JWT_PUBLIC_KEY=

RATE_LIMIT_WRITE_PER_MIN=60
RATE_LIMIT_READ_PER_MIN=240

CHAOS_ENABLED=false
CHAOS_FAIL_PERCENT=0
CHAOS_LATENCY_MS=0

ORDERS_EXCHANGE=orders.x
ORDERS_QUEUE=orders.events
ORDERS_DLQ=orders.dlq

PAYMENTS_EXCHANGE=payments.x
PAYMENTS_INBOUND_QUEUE=orders.payments
PAYMENTS_DLQ=orders.payments.dlq

# Audit log retention: delete entries older than N days (0 = disabled)
AUDIT_RETENTION_DAYS=90

# Production: comma-separated allowed origins (e.g. https://app.example.com)
# Empty in local = CORS allows *
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
