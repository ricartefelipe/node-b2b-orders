{
  "testEnvironment": "node",
  "testMatch": ["**/test/e2e/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)sx?$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2022"
        },
        "module": {
          "type": "commonjs"
        }
      }
    ]
  },
  "transformIgnorePatterns": ["node_modules/(?!(?:uuid|jose)(?:/|$))"]
}
