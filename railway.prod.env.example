# === node-b2b-orders — Railway Environment Variables ===
# Copie para as variáveis do Railway (Settings > Variables)
# Checklist go-live: fluxe-b2b-suite/docs/GO-LIVE-VENDA.md

NODE_ENV=production
# Produção real: APP_ENV=production exige CORS_ORIGINS. No ambiente Railway "staging", use
# APP_ENV=staging (ou deixe em branco) para não bloquear arranque sem lista CORS.
APP_ENV=production
APP_NAME=node-b2b-orders
HTTP_PORT=3000

# PostgreSQL (Railway managed)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Redis (Railway managed)
REDIS_URL=${{Redis.REDIS_URL}}

# RabbitMQ (CloudAMQP free tier) — OBRIGATÓRIO na API e no serviço worker (node-b2b-orders-worker)
RABBITMQ_URL=amqp://user:pass@host:5672

# JWT — DEVE ser o MESMO valor do spring-saas-core (JWT_HS256_SECRET)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET
JWT_ISSUER=spring-saas-core
JWT_ALGORITHM=HS256
TOKEN_EXPIRES_SECONDS=3600

# RS256/OIDC (se core emitir com OIDC, configurar JWKS_URI)
# JWKS_URI=https://auth.seudominio.com.br/realms/fluxe/protocol/openid-connect/certs

# Rate limiting
RATE_LIMIT_WRITE_PER_MIN=60
RATE_LIMIT_READ_PER_MIN=240

# CORS — lista exata dos frontends (produção). Domínio customizado: https://app.fluxe.com.br,https://admin.fluxe.com.br,https://ops.fluxe.com.br
CORS_ORIGINS=https://shop.up.railway.app,https://admin-console.up.railway.app,https://ops-portal.up.railway.app

# Audit
AUDIT_RETENTION_DAYS=90

# Exchanges/Queues
ORDERS_EXCHANGE=orders.x
ORDERS_QUEUE=orders.events
ORDERS_DLQ=orders.dlq
PAYMENTS_EXCHANGE=payments.x
PAYMENTS_INBOUND_QUEUE=orders.payments
PAYMENTS_DLQ=orders.payments.dlq
