# Overrides para rodar na sua MÁQUINA (infra no Docker com portas no host).
# Copie para .env.local (não commitado). Valores aqui sobrescrevem .env.
# Referência: fluxe-b2b-suite/config/env/local.env.example e config/env/README.md

DATABASE_URL=postgresql://app:app@localhost:5435/app
REDIS_URL=redis://localhost:6382
RABBITMQ_URL=amqp://guest:guest@localhost:5675

# JWT igual ao spring-saas-core para aceitar tokens emitidos pelo Core
JWT_SECRET=local-dev-secret-min-32-chars-for-hs256-signing
JWT_ISSUER=spring-saas-core
